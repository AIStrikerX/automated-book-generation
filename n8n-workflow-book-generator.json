    {
      "parameters": {
        "jsCode": "// Parse outline into chapter list\nconst outline = $input.item.json.outline;\nconst lines = outline.split('\\n');\nconst chapters = [];\n\nfor (const line of lines) {\n  const match = line.match(/\\*{0,2}Chapter\\s+(\\d+):\\s*(.+?)\\*{0,2}$/);\n  if (match) {\n    chapters.push({\n      chapter_number: parseInt(match[1]),\n      chapter_title: match[2].trim(),\n      book_title: $input.item.json.title,\n      row_number: $input.item.json.row_number\n    });\n  }\n}\n\nreturn chapters.map(chapter => ({ json: chapter }));"
      },
      "id": "parse-outline-chapters",
      "name": "Parse Outline into Chapters",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [850, 500]
    },
    {
      "parameters": {
        "batchSize": 1,
        "options": {}
      },
      "id": "loop-through-chapters",
      "name": "Loop Through Chapters",
      "type": "n8n-nodes-base.splitInBatches",
      "typeVersion": 3,
      "position": [1050, 500]
    },
    {
      "parameters": {
        "authentication": "apiKey",
        "method": "POST",
        "url": "https://api.groq.com/openai/v1/chat/completions",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "Bearer {{ $env.GROQ_API_KEY }}"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
