        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {
              "name": "model",
              "value": "llama-3.3-70b-versatile"
            },
            {
              "name": "messages",
              "value": "={{ [{ \"role\": \"system\", \"content\": \"You are an expert book writer. Write detailed, engaging chapters.\" }, { \"role\": \"user\", \"content\": \"Write Chapter \" + $json.chapter_number + \" for the book '\" + $json.book_title + \"'\\n\\nChapter Title: \" + $json.chapter_title + \"\\n\\nWrite a comprehensive chapter with clear structure, examples, and engaging content. Aim for 2000-3000 words.\" }] }}"
            },
            {
              "name": "temperature",
              "value": "0.7"
            },
            {
              "name": "max_tokens",
              "value": "8000"
            }
          ]
        },
        "options": {}
      },
      "id": "generate-chapter-groq",
      "name": "Generate Chapter (Groq)",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [1250, 500],
      "retryOnFail": true,
      "maxTries": 3,
      "waitBetweenTries": 30000
    },
    {
      "parameters": {
        "jsCode": "// Store chapter content\nconst chapterNumber = $input.item.json.chapter_number;\nconst chapterContent = $input.item.json.choices[0].message.content;\nconst bookTitle = $input.item.json.book_title;\n\n// Get stored chapters from workflow data or initialize\nconst workflowData = $workflow.staticData || {};\nconst bookId = bookTitle.replace(/\\s+/g, '_');\n\nif (!workflowData[bookId]) {\n  workflowData[bookId] = { chapters: [] };\n}\n\nworkflowData[bookId].chapters.push({\n  chapter_number: chapterNumber,\n  content: chapterContent\n});\n\n$workflow.staticData = workflowData;\n\nreturn [{\n  json: {\n    chapter_number: chapterNumber,\n    chapter_content: chapterContent,\n    book_id: bookId,\n    total_chapters: workflowData[bookId].chapters.length\n  }\n}];"
      },
      "id": "store-chapter",
      "name": "Store Chapter",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1450, 500]
    },
    {
      "parameters": {
        "conditions": {
          "boolean": [
            {
              "value1": "={{ $json.is_last_batch }}",
              "value2": true
            }
          ]
        }
      },
      "id": "check-all-chapters-done",
      "name": "Check: All Chapters Done?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 1,
      "position": [1650, 500]
    },
    {
      "parameters": {
        "jsCode": "// Get all stored chapters\nconst bookTitle = $input.item.json.book_title;\nconst bookId = bookTitle.replace(/\\s+/g, '_');\nconst workflowData = $workflow.staticData || {};\nconst chapters = workflowData[bookId].chapters;\n\n// Sort chapters by number\nchapters.sort((a, b) => a.chapter_number - b.chapter_number);\n\n// Create DOCX content\nlet docxContent = `# ${bookTitle}\\n\\n---\\n\\n## Table of Contents\\n\\n`;\n\nchapters.forEach(ch => {\n  docxContent += `Chapter ${ch.chapter_number}\\n`;\n});\n\ndocxContent += `\\n\\n---\\n\\n`;\n\nchapters.forEach(ch => {\n  docxContent += `# Chapter ${ch.chapter_number}\\n\\n${ch.content}\\n\\n---\\n\\n`;\n});\n\n// Clear stored data\ndelete workflowData[bookId];\n$workflow.staticData = workflowData;\n\nreturn [{\n  json: {\n    book_title: bookTitle,\n    book_content: docxContent,\n    chapter_count: chapters.length\n  }\n}];"
      },
